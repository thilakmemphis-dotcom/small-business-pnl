# Supabase (optional - app works without this using localStorage)
# Get these from https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Postgres API (for full auth - Option B local dev)
# VITE_API_URL must match where the API runs (e.g. http://localhost:3001)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ledger_book
# JWT_SECRET=your-secret-min-32-chars
# VITE_API_URL=http://localhost:3001
